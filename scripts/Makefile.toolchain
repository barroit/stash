find-toolchain := scripts/find-toolchain.py

$(objtree)/cc.info: $(objtree)/toolchain.info
	head -1 $< >$@

$(objtree)/ld.info: $(objtree)/toolchain.info
	tail -1 $< >$@

$(objtree)/toolchain.info:
	mkdir -p $(@D)
	trap 'rm -f .tmp-$$$$' EXIT && \
	$(find-toolchain) >.tmp-$$$$ && \
	mv .tmp-$$$$ $@

$(objtree)/repo.info:
	mkdir -p $(@D)
	printf '%s\t%s\n' $(name) $(version) >$@
